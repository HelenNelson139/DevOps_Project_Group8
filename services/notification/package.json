{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "UIT course registration notification microservice",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:ci": "jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "amqplib": "^0.10.3",
    "nodemailer": "^6.9.7",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "overrides": {
    "glob": "^10.4.6",
    "rimraf": "^5.0.0",
    "npmlog": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@types/amqplib": "^0.10.2",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5.3.3",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
