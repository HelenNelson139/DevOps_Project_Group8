# UIT Đăng ký học phần - Environment variables
# Copy to .env and fill in values. Used by docker-compose and local dev.

# PostgreSQL
POSTGRES_USER=uit
POSTGRES_PASSWORD=uit_secret
POSTGRES_DB=uit_dkhp
POSTGRES_PORT=5433

# Redis
REDIS_URL=redis://localhost:6380
REDIS_PORT=6380

# RabbitMQ
RABBITMQ_USER=uit
RABBITMQ_PASSWORD=uit_secret

# API Gateway (host port for browser access)
GATEWAY_PORT=8081

# Auth Service - JWT
JWT_SECRET=nhom-8-sieu-cap-dep-trai-xinh-gai
JWT_EXPIRES_IN=7d

# Mailtrap (for local email testing)
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=
MAIL_FROM=noreply@uit-dkhp.local

# Optional: per-service override when running outside Docker
# DATABASE_URL=postgresql://uit:uit_secret@localhost:5433/uit_dkhp
# RABBITMQ_URL=amqp://uit:uit_secret@localhost:5673
